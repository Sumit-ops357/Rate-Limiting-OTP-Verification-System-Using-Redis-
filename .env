# Environment variables extracted from application.properties
SPRING_APPLICATION_NAME=system-design-java-project1

# Server Configuration
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# Redis Configuration
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=
SPRING_REDIS_DATABASE=0
SPRING_REDIS_TIMEOUT=2000ms
SPRING_REDIS_JEDIS_POOL_MAX_ACTIVE=8
SPRING_REDIS_JEDIS_POOL_MAX_IDLE=8
SPRING_REDIS_JEDIS_POOL_MIN_IDLE=0

# Application Configuration
APP_RATE_LIMIT_MAX_REQUESTS=5
APP_RATE_LIMIT_WINDOW_MINUTES=1
APP_OTP_EXPIRY_MINUTES=5
APP_OTP_LENGTH=6
